{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Time Accountability",
  "version": "0.1.0",
  "identifier": "com.bilal.time-accountability",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Time Accountability",
        "width": 360,
        "height": 900,
        "decorations": false,
        "shadow": true,
        "minWidth": 64,
        "minHeight": 400,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
